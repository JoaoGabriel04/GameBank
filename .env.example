# ─── Database ───────────────────────────
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=supermaquina
DB_PORT=5432

# ─── Server ─────────────────────────────
SERVER_PORT=7000
CORS_ORIGIN=http://localhost:3000

# ─── Client ─────────────────────────────
CLIENT_PORT=3000
API_URL=http://localhost:7000/api
CLIENT_URL=http://localhost:3000
GAME_VERSION=1.0.0

# ─── Auth ────────────────────────────────
JWT_SECRET=coloque-uma-chave-segura-aqui
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Mercado Pago ────────────────────────────────
MP_ACCESS_TOKEN=           # Access token (TEST-... para sandbox, APP_USR-... para produção)
MP_WEBHOOK_SECRET=         # Secret para validar assinatura x-signature do webhook
SERVER_URL=http://localhost:7000  # URL pública do servidor (usado no notification_url do webhook)

# ─── Cloudinary (avatars + banners) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Opcional: pasta no Cloudinary (padrão gamebank/avatars / gamebank/banners)
CLOUDINARY_AVATAR_FOLDER=gamebank/avatars
CLOUDINARY_BANNER_FOLDER=gamebank/banners
# Limites avatar (opcional)
AVATAR_MAX_BYTES=5242880
AVATAR_MIN_DIM=100
AVATAR_MAX_DIM=4096
AVATAR_OUTPUT_SIZE=512
AVATAR_UPLOAD_RATE_LIMIT=5
# Limites banner (opcional) — banner é paisagem 1200x400
BANNER_MAX_BYTES=8388608
BANNER_MIN_DIM=600
BANNER_MAX_DIM=4096
BANNER_OUTPUT_WIDTH=1200
BANNER_OUTPUT_HEIGHT=400
BANNER_UPLOAD_RATE_LIMIT=5
