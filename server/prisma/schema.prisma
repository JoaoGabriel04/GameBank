// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums de estado (valores = exatamente o que já está gravado no DB) ──────────
// Deferidos de propósito (legado/acoplamento): Session.status ("Em Andamento" tem
// espaço + acoplamento com o client), Card.tipo/efeito (acento + conteúdo de admin)
// e Coin/DiamondTransaction.tipo (campo "tipo" sobrecarregado entre tabelas).
enum Raridade {
  COMUM
  INCOMUM
  RARO
  EPICO
  LENDARIO
}

enum ShopItemType {
  title
  badge
  banner
  frame
}

enum NegotiationStatus {
  pendente
  aceita
  recusada
  expirada
}

enum NotificationStatus {
  pendente
  aceita
  recusada
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AuditSeverity {
  info
  success
  warn
  danger
}

enum BauStatus {
  BLOQUEADO
  PRONTO
}

enum FrameTipo {
  image
  gradient
}

enum MissionTipo {
  daily
  weekly
}

enum MissionMetric {
  properties_bought
  houses_built
  rent_earned
  games_played
  wins
  top3
}

enum SessionModo {
  individual
  duplas
}

model Propriedade {
  id            Int    @id
  nome          String
  grupo_cor     String
  tipo          String
  custo_compra  Int
  aluguel_base  Int
  aluguel_1c    Int
  aluguel_2c    Int
  aluguel_3c    Int
  aluguel_4c    Int
  aluguel_hotel Int
  custo_casa    Int
  hipoteca      Int

  sessionPosses SessionPosses[]

  @@map("propriedades")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String?
  nome         String
  googleId     String?   @unique
  discordId    String?   @unique
  avatarUrl        String?
  avatarPublicId   String?
  avatarUpdatedAt  DateTime?
  banner           String?
  frame            String?
  frameType        String?   @map("frametype")
  frameAnimated    Boolean   @default(false) @map("frameanimated")
  frameScale       Int       @default(136)
  profileComplete  Boolean   @default(false)
  isAdmin          Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("createdAt")

  level        Int       @default(1)
  xp           Int       @default(0)
  coins        Int       @default(0)
  diamonds     Int       @default(0)
  totalGames   Int       @default(0)
  totalWins    Int       @default(0)
  totalTop3    Int       @default(0)
  trophies     Int       @default(0)

  banned       Boolean   @default(false)
  bannedAt     DateTime?
  banReason    String?

  user_items   Json      @default("[]") @map("items")

  sessions             Session[]
  players              SessionPlayer[]
  missions             UserMission[]
  fragments            UserFragment[]
  dailyOffers          UserDailyOffer[]
  gameResults          GameResult[]
  diamondTransactions  DiamondTransaction[]
  diamondPurchases     DiamondPurchase[]
  coinTransactions     CoinTransaction[]
  auditLogs            AuditLog[]
  userNotifications    UserNotification[]

  bauAdquiridos BauAdquirido[]

  @@map("users")
}

model Session {
  id           Int      @id @default(autoincrement())
  nome         String? // opcional
  senha        String? // bcrypt hash, null = sala pública
  modo         SessionModo @default(individual)
  status       String  @default("Esperando")  // "Esperando" | "Em Andamento" | "Finalizada"
  maxJogadores Int     @default(6)
  saldoInicial Int     @default(25000)
  dataInicio   DateTime @default(now())
  startedAt    DateTime?            // momento em que a partida começou de fato (status -> Em Andamento)
  rewardGranted Boolean @default(false) // proteção contra duplo crédito de recompensa
  ownerId      Int?
  owner        User?    @relation(fields: [ownerId], references: [id])

  sessionPosses SessionPosses[]
  historico     Historico[]
  jogadores     SessionPlayer[]
  times         SessionTeam[]
  messages      Message[]
  notifications Notification[]
  negotiations Negotiation[]
  debts        Debt[]
  coinTransactions CoinTransaction[]
  bauAdquiridos    BauAdquirido[]

  @@index([ownerId])
  @@map("sessions")
}

// Jogadores "fictícios" dentro da sessão
model SessionPlayer {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])
  userId    Int?    // link para User (dono do jogador) — User.id (JWT)
  user      User?   @relation(fields: [userId], references: [id])

  nome   String
  cor    String
  saldo  Int
  teamId Int?
  team   SessionTeam? @relation(fields: [teamId], references: [id])

  sessionPosses SessionPosses[]
  lastOwned     SessionPosses[] @relation("LastOwner")
  messages      Message[]
  notificationsFrom Notification[] @relation("NotificationFromPlayer")
  notificationsTo   Notification[] @relation("NotificationToPlayer")
  carta_prisao        Boolean   @default(false)
  desistiu            Boolean   @default(false)
  patrimonyAtDesistir Int?
  motivoDesistencia   String?   // "FALENCIA" | "VOLUNTARIA" | null (ainda em jogo)
  desistiuEm          DateTime?
  negotiationsFrom  Negotiation[] @relation("NegotiationFromPlayer")
  negotiationsTo    Negotiation[] @relation("NegotiationToPlayer")
  debts             Debt[]

  @@index([userId])
  @@index([sessionId])
  @@index([teamId])
  @@map("session_players")
}

// Times para modo duplas
model SessionTeam {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])

  nome      String
  cor       String
  saldo     Int       @default(25000)
  jogadores SessionPlayer[]

  @@map("session_teams")
}

// Estado das propriedades dentro de uma sessão (referencia Propriedade direto)
model SessionPosses {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])

  propId      Int
  propriedade Propriedade @relation(fields: [propId], references: [id])

  playerId Int?
  player   SessionPlayer? @relation(fields: [playerId], references: [id])

  lastOwnerId Int?
  lastOwner    SessionPlayer? @relation("LastOwner", fields: [lastOwnerId], references: [id])

  casas      Int     @default(0)
  hipotecada Boolean @default(false)
  negociando Boolean @default(false)

  notifications    Notification[]
  negotiationItems NegotiationItem[]

  @@index([sessionId])
  @@index([playerId])
  @@index([sessionId, playerId])
  @@index([propId])
  @@index([lastOwnerId])
  @@map("session_posses")
}

// Histórico de transações
model Historico {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])

  data     DateTime
  tipo     String
  detalhes String

  @@index([sessionId])
  @@map("historico")
}

// Mensagens de chat da sala
model Message {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  playerId  Int
  player    SessionPlayer @relation(fields: [playerId], references: [id])
  texto     String
  createdAt DateTime @default(now()) @map("createdAt")

  @@index([sessionId])
  @@index([playerId])
  @@map("messages")
}

// Notificações entre jogadores (compra de hipotecada, etc)
model Notification {
  id              Int         @id @default(autoincrement())
  sessionId       Int
  session         Session     @relation(fields: [sessionId], references: [id])
  tipo            String
  fromPlayerId    Int
  fromPlayer      SessionPlayer @relation("NotificationFromPlayer", fields: [fromPlayerId], references: [id])
  toPlayerId      Int
  toPlayer        SessionPlayer @relation("NotificationToPlayer", fields: [toPlayerId], references: [id])
  sessionPossesId Int
  sessionPosses   SessionPosses @relation(fields: [sessionPossesId], references: [id], onDelete: Cascade)
  status          NotificationStatus @default(pendente)
  createdAt       DateTime    @default(now()) @map("createdAt")
  respondedAt     DateTime?

  @@index([sessionId])
  @@index([toPlayerId])
  @@index([sessionPossesId])
  @@map("notifications")
}

model Negotiation {
  id              Int      @id @default(autoincrement())
  sessionId       Int
  session         Session  @relation(fields: [sessionId], references: [id])
  fromPlayerId    Int
  fromPlayer      SessionPlayer @relation("NegotiationFromPlayer", fields: [fromPlayerId], references: [id])
  toPlayerId      Int
  toPlayer        SessionPlayer @relation("NegotiationToPlayer", fields: [toPlayerId], references: [id])
  status          NegotiationStatus @default(pendente)
  expiresAt       DateTime?
  createdAt       DateTime @default(now()) @map("createdAt")
  respondedAt     DateTime?

  items NegotiationItem[]

  @@index([sessionId])
  @@index([fromPlayerId])
  @@index([toPlayerId])
  @@index([status])
  @@map("negociacoes")
}

model NegotiationItem {
  id              Int     @id @default(autoincrement())
  negotiationId   Int
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id])
  sessionPossesId Int?
  sessionPosses   SessionPosses? @relation(fields: [sessionPossesId], references: [id], onDelete: SetNull)
  fromSide        Boolean
  valor           Int?

  @@index([sessionPossesId])
  @@map("negociacao_itens")
}

model Debt {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  playerId  Int
  player    SessionPlayer @relation(fields: [playerId], references: [id])
  valor     Int
  descricao String
  pago      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("createdAt")
  paidAt    DateTime?

  @@index([playerId])
  @@index([sessionId])
  @@map("dividas")
}

model Mission {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  metric      MissionMetric
  target      Float
  xpReward    Int
  coinReward  Int
  tipo        MissionTipo @default(daily)

  userMissions UserMission[]

  @@map("missoes")
}

model UserMission {
  id          Int       @id @default(autoincrement())
  userId      Int
  missionId   Int
  progress    Float     @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  claimed     Boolean   @default(false)
  claimedAt   DateTime?
  expiresAt   DateTime?
  generatedAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])

  @@unique([userId, missionId])
  @@map("usuario_missoes")
}

model Badge {
  id             Int      @id @default(autoincrement())
  nome           String
  imageUrl       String?
  imagePublicId  String?
  disponibilidade Boolean @default(true)
  createdAt      DateTime @default(now())

  shopItems ShopItem[]

  @@map("badges")
}

model ShopItem {
  id            Int      @id @default(autoincrement())
  name          String
  description   String
  price         Int
  diamondPrice  Int?
  icon          String?
  type          ShopItemType
  value         String?
  raridade      Raridade @default(COMUM)
  imageUrl      String?  // Cloudinary URL for badge images
  imagePublicId String?  // Cloudinary public ID for deletion
  available     Boolean  @default(true)
  animated      Boolean  @default(false)

  fragmentavel    Boolean  @default(false)
  fragmentosTotal Int?
  fragmentosIcone String?

  bannerId Int?
  banner   Banner? @relation(fields: [bannerId], references: [id], onDelete: SetNull)

  frameId Int?
  frame   Frame?  @relation(fields: [frameId], references: [id], onDelete: SetNull)

  badgeId Int?
  badge   Badge?  @relation(fields: [badgeId], references: [id], onDelete: SetNull)

  fragments    UserFragment[]
  dailyOffers  UserDailyOffer[]
  diamondTransactions DiamondTransaction[]

  @@index([bannerId])
  @@index([frameId])
  @@index([badgeId])
  @@map("loja_itens")
}

model UserFragment {
  id         Int      @id @default(autoincrement())
  userId     Int
  itemId     Int
  quantidade Int      @default(0)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  user User     @relation(fields: [userId], references: [id])
  item ShopItem @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@map("user_fragments")
}

model UserDailyOffer {
  id         Int      @id @default(autoincrement())
  userId     Int
  itemId     Int
  preco      Int
  quantidade Int
  expiresAt  DateTime
  purchased  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User     @relation(fields: [userId], references: [id])
  item ShopItem @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId, expiresAt])
  @@map("user_daily_offers")
}

model Bau {
  id            Int     @id @default(autoincrement())
  tipo          String  @unique
  nome          String
  descricao     String
  precoCoins    Int?
  precoDiamonds Int?
  ativo         Boolean @default(true)

  adquiridos   BauAdquirido[]

  @@map("baus")
}

model BauAdquirido {
  id        Int       @id @default(autoincrement())
  userId    Int
  bauId     Int
  sessionId Int?
  position  Int?
  status    BauStatus @default(BLOQUEADO)
  unlockAt  DateTime
  openedAt  DateTime?
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id])
  bau     Bau      @relation(fields: [bauId],  references: [id])
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, unlockAt])
  @@index([sessionId])
  @@map("baus_adquiridos")
}

model GameResult {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  userId      Int
  position    Int
  patrimony   Int
  xpEarned    Int      @default(0)
  coinsEarned Int      @default(0)
  trophyDelta  Int     @default(0)
  trophyBefore Int     @default(0)
  trophyAfter  Int     @default(0)

  // Auditoria do sistema anti-farm
  activityScore    Int     @default(0)   // score de participação na partida
  rewardMultiplier Float   @default(1.0) // multiplicador aplicado
  penaltyReason    String?               // motivo se recompensa foi reduzida

  createdAt   DateTime @default(now()) @map("createdAt")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, sessionId]) // um resultado por jogador por partida
  @@index([userId])
  @@index([sessionId])
  @@map("resultados_partidas")
}

// Auditoria imutável de toda movimentação de coins
model CoinTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int      // positivo = crédito, negativo = débito
  tipo      String   // "PARTIDA" | "MISSAO" | "LOJA_COMPRA" | "LOJA_VENDA" | "ADMIN"
  sessionId Int?     // referência à partida se tipo = PARTIDA
  createdAt DateTime @default(now()) @map("createdAt")

  user    User     @relation(fields: [userId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([sessionId])
  @@map("coin_transactions")
}

model DiamondTransaction {
  id              Int      @id @default(autoincrement())
  userId          Int
  quantidade      Int
  tipo            String   // "COMPRA" | "GASTO_LOJA" | "ESTORNO" | "ADMIN"
  paymentIntentId String?  @unique
  purchaseId      String?
  itemId          Int?
  note            String?
  createdAt       DateTime @default(now()) @map("createdAt")

  user     User             @relation(fields: [userId], references: [id])
  purchase DiamondPurchase? @relation(fields: [purchaseId], references: [id])
  item     ShopItem?        @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([purchaseId])
  @@index([itemId])
  @@map("diamond_transactions")
}

// Pacotes de diamantes disponíveis para compra
model DiamondPackage {
  id           Int      @id @default(autoincrement())
  name         String
  description  String   @default("")
  diamonds     Int
  bonusPct     Int      @default(0)
  priceInCents Int
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("createdAt")

  purchases DiamondPurchase[]

  @@map("diamond_packages")
}

// Registro de cada compra de diamantes — imutável após COMPLETED
model DiamondPurchase {
  id                 String   @id @default(cuid())
  userId             Int
  packageId          Int
  diamondsGranted    Int
  amountPaidCents    Int
  currency           String   @default("BRL")
  mpPaymentId        String?  @unique
  mpPreferenceId     String?
  mpIdempotencyKey   String   @unique
  paymentMethod      String?
  status             PurchaseStatus
  createdAt          DateTime @default(now()) @map("createdAt")
  completedAt        DateTime?

  user                 User                 @relation(fields: [userId], references: [id])
  package              DiamondPackage       @relation(fields: [packageId], references: [id])
  diamondTransactions  DiamondTransaction[]

  @@index([userId])
  @@index([status])
  @@map("diamond_purchases")
}

model Card {
  id      Int     @id @default(autoincrement())
  tipo    String  // "sorte" | "revés"
  texto   String
  efeito  String  // "ganhar" | "pagar" | "pagarPct" | "pagarPorCasa" | "prisao" | "sairPrisao"
  valor   Int     @default(0)
  ativo   Boolean @default(true)
  createdAt DateTime @default(now()) @map("createdAt")

  @@map("cartas")
}

model GameSettings {
  key   String   @id @unique
  value String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("jogo_configuracoes")
}

model Banner {
  id              Int      @id @default(autoincrement())
  nome            String
  css             String           // pode ser URL https:// OU gradiente CSS
  animated        Boolean  @default(false)
  imagePublicId   String?          // public_id do Cloudinary (para deleção)
  imageUpdatedAt  DateTime?        // última vez que a imagem foi trocada
  disponibilidade Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("createdAt")

  shopItems ShopItem[]

  @@map("banners")
}

model Frame {
  id              Int      @id @default(autoincrement())
  nome            String
  tipo            FrameTipo @default(gradient)

  // Para tipo "image":
  imageUrl        String?  @map("imageurl") // URL do PNG no Cloudinary
  imagePublicId   String?  @map("imagepublicid") // public_id para deleção futura

  // Para tipo "gradient":
  css             String?  // ex: "linear-gradient(-45deg, #ee7752, #e73c7e)"
  animated        Boolean  @default(false)
  scale           Int      @default(136)

  disponibilidade Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("createdat")

  shopItems ShopItem[]

  @@map("frames")
}

model UserNotification {
  id        Int       @id @default(autoincrement())
  userId    Int
  titulo    String
  corpo     String
  lida      Boolean   @default(false)
  lidaEm    DateTime?
  createdAt DateTime  @default(now()) @map("createdAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_notifications")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  target    String?
  metadata  Json?
  severity  AuditSeverity @default(info)
  createdAt DateTime @default(now()) @map("createdAt")

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}
