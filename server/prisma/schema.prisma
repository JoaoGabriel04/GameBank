// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Propriedade {
  id            Int    @id
  nome          String
  grupo_cor     String
  tipo          String
  custo_compra  Int
  aluguel_base  Int
  aluguel_1c    Int
  aluguel_2c    Int
  aluguel_3c    Int
  aluguel_4c    Int
  aluguel_hotel Int
  custo_casa    Int
  hipoteca      Int

  posses Posses[]

  @@map("propriedades")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String?
  nome         String
  googleId     String?   @unique
  discordId    String?   @unique
  avatarUrl        String?
  avatarPublicId   String?
  avatarUpdatedAt  DateTime?
  banner           String?   @default("preset:banner-01")
  profileComplete  Boolean   @default(false)
  isAdmin          Boolean   @default(false)
  createdAt        DateTime  @default(now())

  level        Int       @default(1)
  xp           Int       @default(0)
  coins        Int       @default(0)
  totalGames   Int       @default(0)
  totalWins    Int       @default(0)
  totalTop3    Int       @default(0)

  sessions        Session[]
  players         SessionPlayer[]
  missions        UserMission[]
  items           UserItem[]
  gameResults     GameResult[]

  @@map("users")
}

model Session {
  id           Int      @id @default(autoincrement())
  nome         String? // opcional
  senha        String? // bcrypt hash, null = sala pública
  modo         String  @default("individual") // "individual" | "duplas"
  status       String  @default("Esperando")  // "Esperando" | "Em Andamento" | "Finalizada"
  maxJogadores Int     @default(6)
  saldoInicial Float   @default(25000)
  dataInicio   DateTime @default(now())
  ownerId      Int?
  owner        User?    @relation(fields: [ownerId], references: [id])

  sessionPosses SessionPosses[]
  historico     Historico[]
  jogadores     SessionPlayer[]
  times         SessionTeam[]
  messages      Message[]
  notifications Notification[]
  negotiations Negotiation[]
  debts        Debt[]

  @@map("sessions")
}

// Jogadores "fictícios" dentro da sessão
model SessionPlayer {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])
  userId    Int?    // link para User (dono do jogador) — User.id (JWT)
  user      User?   @relation(fields: [userId], references: [id])

  nome   String
  cor    String
  saldo  Float
  teamId Int?
  team   SessionTeam? @relation(fields: [teamId], references: [id])

  sessionPosses SessionPosses[]
  lastOwned     SessionPosses[] @relation("LastOwner")
  messages      Message[]
  notificationsFrom Notification[] @relation("NotificationFromPlayer")
  notificationsTo   Notification[] @relation("NotificationToPlayer")
  carta_prisao      Boolean @default(false)
  desistiu          Boolean @default(false)
  patrimonyAtDesistir Float?
  negotiationsFrom  Negotiation[] @relation("NegotiationFromPlayer")
  negotiationsTo    Negotiation[] @relation("NegotiationToPlayer")
  debts             Debt[]

  @@index([userId])
  @@index([sessionId])
  @@map("session_players")
}

// Times para modo duplas
model SessionTeam {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])

  nome      String
  cor       String
  saldo     Float     @default(25000)
  jogadores SessionPlayer[]

  @@map("session_teams")
}

// Posses base do jogo (globais)
model Posses {
  id          Int         @id @default(autoincrement())
  id_prop     Int
  propriedade Propriedade @relation(fields: [id_prop], references: [id])

  casas      Int     @default(0)
  hipotecada Boolean @default(false)

  sessionPosses SessionPosses[]

  @@map("posses")
}

// Estado das posses dentro de uma sessão
model SessionPosses {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])

  possesId Int
  posses   Posses @relation(fields: [possesId], references: [id])

  playerId Int?
  player   SessionPlayer? @relation(fields: [playerId], references: [id])

  lastOwnerId Int?
  lastOwner    SessionPlayer? @relation("LastOwner", fields: [lastOwnerId], references: [id])

  casas      Int     @default(0)
  hipotecada Boolean @default(false)
  negociando Boolean @default(false)

  @@index([sessionId])
  @@index([playerId])
  @@index([sessionId, playerId])
  @@map("session_posses")
}

// Histórico de transações
model Historico {
  id        Int     @id @default(autoincrement())
  sessionId Int
  session   Session @relation(fields: [sessionId], references: [id])

  data     DateTime
  tipo     String
  detalhes String

  @@index([sessionId])
  @@map("historico")
}

// Mensagens de chat da sala
model Message {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  playerId  Int
  player    SessionPlayer @relation(fields: [playerId], references: [id])
  texto     String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("messages")
}

// Notificações entre jogadores (compra de hipotecada, etc)
model Notification {
  id              Int         @id @default(autoincrement())
  sessionId       Int
  session         Session     @relation(fields: [sessionId], references: [id])
  tipo            String
  fromPlayerId    Int
  fromPlayer      SessionPlayer @relation("NotificationFromPlayer", fields: [fromPlayerId], references: [id])
  toPlayerId      Int
  toPlayer        SessionPlayer @relation("NotificationToPlayer", fields: [toPlayerId], references: [id])
  sessionPossesId Int
  status          String      @default("pendente") // "pendente" | "aceita" | "recusada"
  createdAt       DateTime    @default(now())
  respondedAt     DateTime?

  @@index([sessionId])
  @@index([toPlayerId])
  @@map("notifications")
}

model Negotiation {
  id              Int      @id @default(autoincrement())
  sessionId       Int
  session         Session  @relation(fields: [sessionId], references: [id])
  fromPlayerId    Int
  fromPlayer      SessionPlayer @relation("NegotiationFromPlayer", fields: [fromPlayerId], references: [id])
  toPlayerId      Int
  toPlayer        SessionPlayer @relation("NegotiationToPlayer", fields: [toPlayerId], references: [id])
  status          String   @default("pendente")
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  respondedAt     DateTime?

  items NegotiationItem[]

  @@index([sessionId])
  @@index([fromPlayerId])
  @@index([toPlayerId])
  @@index([status])
  @@map("negociacoes")
}

model NegotiationItem {
  id              Int     @id @default(autoincrement())
  negotiationId   Int
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id])
  sessionPossesId Int?
  fromSide        Boolean
  valor           Float?

  @@map("negociacao_itens")
}

model Debt {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  playerId  Int
  player    SessionPlayer @relation(fields: [playerId], references: [id])
  valor     Float
  descricao String
  pago      Boolean  @default(false)
  createdAt DateTime @default(now())
  paidAt    DateTime?

  @@index([playerId])
  @@index([sessionId])
  @@map("dividas")
}

model Mission {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  metric      String   // properties_bought | houses_built | rent_earned | games_played | wins | top3
  target      Float
  xpReward    Int
  coinReward  Int
  perGame     Boolean  @default(false)
  active      Boolean  @default(true)

  userMissions UserMission[]

  @@map("missoes")
}

model UserMission {
  id          Int       @id @default(autoincrement())
  userId      Int
  missionId   Int
  progress    Float     @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])

  @@unique([userId, missionId])
  @@map("usuario_missoes")
}

model ShopItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  icon        String?
  type        String   // title | badge | color
  value       String?
  available   Boolean  @default(true)

  userItems UserItem[]

  @@map("loja_itens")
}

model UserItem {
  id         Int       @id @default(autoincrement())
  userId     Int
  itemId     Int
  equipped   Boolean   @default(false)
  acquiredAt DateTime  @default(now())

  user User     @relation(fields: [userId], references: [id])
  item ShopItem @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@map("usuario_itens")
}

model GameResult {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  userId      Int
  position    Int
  patrimony   Float
  xpEarned    Int      @default(0)
  coinsEarned Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@map("resultados_partidas")
}

model Card {
  id      Int     @id @default(autoincrement())
  tipo    String  // "sorte" | "revés"
  texto   String
  efeito  String  // "ganhar" | "pagar" | "pagarPct" | "pagarPorCasa" | "prisao" | "sairPrisao"
  valor   Int     @default(0)
  ativo   Boolean @default(true)
  createdAt DateTime @default(now())

  @@map("cartas")
}

model GameSettings {
  key   String   @id @unique
  value String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("jogo_configuracoes")
}

model Banner {
  id        Int     @id @default(autoincrement())
  nome      String
  css       String
  spriteId  String?
  disponibilidade Boolean @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}
